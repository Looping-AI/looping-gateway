{
  "name": "looping-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "Slack Agent Template: Cloudflare hosted, Slack-anchored multi-agent gateway with A2A routing",
  "keywords": [
    "agents",
    "ai",
    "cloudflare",
    "slack"
  ],
  "license": "GPL-3.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "types": "wrangler types env.d.ts --include-runtime false",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "prettier --check . && eslint . && tsc && tsc -p test/tsconfig.json"
  },
  "dependencies": {
    "@chat-adapter/slack": "^4.30.0",
    "agents": "^0.16.0",
    "ai": "^6.0.204",
    "chat": "^4.30.0",
    "workers-ai-provider": "^3.1.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.15",
    "@cloudflare/workers-types": "^4.20260612.1",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "prettier": "^3.5.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  }
}

{
  "name": "looping-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "Slack Agent Template: Cloudflare hosted, Slack-anchored multi-agent gateway with A2A routing",
  "keywords": [
    "agents",
    "ai",
    "cloudflare",
    "slack"
  ],
  "license": "GPL-3.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "types": "wrangler types env.d.ts --include-runtime false",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply looping-registry --local",
    "db:migrate": "wrangler d1 migrations apply looping-registry --remote",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "prettier --check . && eslint . && tsc && tsc -p test/tsconfig.json",
    "prepare": "husky"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@chat-adapter/slack": "^4.30.0",
    "agents": "^0.16.0",
    "ai": "^6.0.205",
    "chat": "^4.30.0",
    "drizzle-orm": "^0.45.2",
    "slackify-markdown": "github:Looping-AI/slackify-markdown#5.0.0",
    "workers-ai-provider": "^3.1.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.15",
    "@cloudflare/workers-types": "^4.20260615.1",
    "@types/node": "^25.9.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.100.0"
  }
}
